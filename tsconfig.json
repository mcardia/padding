{
  "compilerOptions": {
    "target": "ES2016",
    "lib": ["ES2016"],
    "module": "none",
    "ignoreDeprecations": "6.0",
    "outFile": "pkg/contents/code/main.js",
    "rootDir": "src",
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": false,
    "declaration": false,
    "removeComments": false,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}
